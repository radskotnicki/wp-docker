# WordPress Docker Environment Configuration
# Copy this file to .env and fill in your values
# Or use: make setup (interactive wizard)

# Project name (used for container, volume, and network names)
# e.g. "mysite" → containers: mysite-wordpress-1, mysite-db-1
COMPOSE_PROJECT_NAME=wp-docker

# Port for WordPress (host:container 80)
WP_PORT=8080

# PHP version (available: 8.0, 8.1, 8.2, 8.3, 8.4)
# After changing, rebuild: make build
PHP_VERSION=8.2

# MySQL version (available: 5.7, 8.0, 8.4)
# After changing: make clean && make up  (WARNING: deletes local database)
MYSQL_VERSION=8.0

# Xdebug (PHP debugger for VS Code / PhpStorm)
# Set to true, then rebuild: make build
# Listens on port 9003 — configure your editor to connect
XDEBUG_ENABLE=false

# MySQL/MariaDB Configuration
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=wordpress
MYSQL_USER=wp
MYSQL_PASSWORD=change_me_password

# Optional: WordPress table prefix (default: wp_)
# WORDPRESS_TABLE_PREFIX=wp_
